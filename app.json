{
  "expo": {
    "name": "AlloteMe",
    "slug": "alloteme0077",
    "version": "1.0.0",
    "scheme": "alloteme0077",
    "orientation": "portrait",
    "icon": "./imgs/logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./imgs/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alloteme.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./imgs/logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.alloteme.mobile",
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": {
            "scheme": "alloteme0077"
          },
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.WAKE_LOCK",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.VIBRATE"
      ],
      "notification": {
        "icon": "./imgs/logo.png",
        "color": "#0A66C2"
      },
      "statusBar": {
        "barStyle": "light-content",
        "backgroundColor": "#0A66C2"
      }
    },
    "web": {
      "favicon": "./imgs/logo.png"
    },
    "plugins": [
      "./withAndroidXFix",
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "enableJetifier": true,
            "packagingOptions": {
              "pickFirst": [
                "**/INotificationSideChannel.aidl",
                "**/IResultReceiver.aidl",
                "**/IconCompatParcelizer.java",
                "**/androidx/versionedparcelable/*",
                "META-INF/androidx.*.version",
                "META-INF/*.version"
              ]
            }
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./imgs/logo.png",
          "color": "#0A66C2",
          "mode": "production",
          "androidMode": "default",
          "androidCollapsedTitle": "#{unread_notifications} new notifications"
        }
      ],
      "expo-font"
    ],
    "notification": {
      "iosDisplayInForeground": true,
      "androidMode": "default",
      "androidCollapsedTitle": "#{unread_notifications} new notifications"
    },
    "extra": {
      "eas": {
        "projectId": "3f4b8fb1-5b7e-48b4-9388-31718f3ff000"
      }
    }
  }
}
