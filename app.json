{
  "expo": {
    "name": "Mavericks",
    "slug": "mavericks",
    "version": "1.0.0",
    "scheme": "mavericks",
    "orientation": "portrait",
    "icon": "./assets/padded_icon.png",
    "userInterfaceStyle": "automatic",
    "extra": {
      "eas": {
        "projectId": "c17b5aac-9e6c-4e09-ae8f-9309e8f25b22"
      }
    },
    "splash": {
      "image": "./assets/AS.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mavericks.clubmanagement"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/padded_icon.png",
        "backgroundColor": "#0A66C2"
      },
      "package": "com.mycompany.myauth",
      "usesCleartextTraffic": true,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "NOTIFICATIONS"
      ],
      "notification": {
        "icon": "./assets/AS.png",
        "color": "#0A66C2"
      }
    },
    "web": {
      "favicon": "./assets/AS.png"
    },
    "plugins": [
      "./withAndroidXFix",
      "@react-native-community/datetimepicker",
      "@react-native-voice/voice",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "enableJetifier": true,
            "packagingOptions": {
              "pickFirst": [
                "**/INotificationSideChannel.aidl",
                "**/IResultReceiver.aidl",
                "**/IconCompatParcelizer.java",
                "**/androidx/versionedparcelable/*",
                "META-INF/androidx.*.version",
                "META-INF/*.version"
              ]
            }
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/AS.png",
          "color": "#0A66C2"
        }
      ]
    ],
    "owner": "shivamdombe"
  }
}